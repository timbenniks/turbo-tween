{
  "name": "@timbenniks/turbo-tween",
  "version": "0.1.1",
  "description": "GSAP ergonomics in ~5KB. Turbo Tween is a lightweight, type-safe tweening library for modern web apps",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && vp exec tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "vp exec tsc --noEmit",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "test:e2e": "vp exec playwright test",
    "lint": "vp lint src/ tests/",
    "format": "vp fmt .",
    "format:check": "vp fmt --check .",
    "changeset": "vp exec changeset",
    "version": "vp exec changeset version",
    "release": "vp build && vp exec tsc -p tsconfig.build.json --emitDeclarationOnly && vp exec changeset publish",
    "size": "vp exec size-limit",
    "prepare": "vp config"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^12.0.1",
    "typescript": "^5.9.3",
    "vue": "^3.5.30",
    "vite-plus": "latest"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "5 KB",
      "name": "core entry"
    },
    {
      "path": [
        "dist/index.js",
        "dist/timeline-*.js"
      ],
      "limit": "9 KB",
      "name": "core + shared"
    }
  ],
  "keywords": [
    "tween",
    "animation",
    "easing",
    "vue",
    "react",
    "gsap",
    "motion",
    "transition",
    "typescript"
  ],
  "license": "MIT",
  "author": "Tim Benniks",
  "repository": {
    "type": "git",
    "url": "https://github.com/timbenniks/turbo-tween"
  },
  "packageManager": "pnpm@10.32.1"
}
