{
  "name": "@timbenniks/turbo-tween",
  "version": "0.1.0",
  "description": "GSAP ergonomics in ~5KB. Turbo Tween is a lightweight, type-safe tweening library for modern web apps",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "size": "size-limit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^11.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.29"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "5 KB",
      "name": "core entry"
    },
    {
      "path": [
        "dist/index.js",
        "dist/timeline-*.js"
      ],
      "limit": "9 KB",
      "name": "core + shared"
    }
  ],
  "keywords": [
    "tween",
    "animation",
    "easing",
    "vue",
    "react",
    "gsap",
    "motion",
    "transition",
    "typescript"
  ],
  "license": "MIT",
  "author": "Tim Benniks",
  "repository": {
    "type": "git",
    "url": "https://github.com/timbenniks/turbo-tween"
  }
}
